# DOMBA Application Configuration Template
# Copy this file to .env and adjust values for your environment

# ============================================================================
# FLASK & APPLICATION SETTINGS
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production
PORT=8000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string format:
# postgresql://username:password@host:port/database_name

DATABASE_URL=postgresql://domba_user:password_anda@localhost:5432/domba_db

# Alternative: Individual database parameters (used if DATABASE_URL not provided)
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=domba_db

# ============================================================================
# BACKUP & DISASTER RECOVERY CONFIGURATION
# ============================================================================

# Backup directory location (relative or absolute path)
# Default: ./backups (relative to application root)
# For production, use absolute path like: /var/backups/domba
BACKUP_LOCATION=./backups

# Backup retention policy (days)
# Backups older than this will be automatically deleted
# Default: 30 days
BACKUP_RETENTION_DAYS=30

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# CSRF Protection
WTF_CSRF_ENABLED=true

# Session configuration
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict
PERMANENT_SESSION_LIFETIME=3600

# ============================================================================
# OPTIONAL: EMAIL NOTIFICATIONS (Future Enhancement)
# ============================================================================
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-password
# MAIL_DEFAULT_SENDER=domba-notification@example.com

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================
#
# 1. SECURITY CHECKLIST:
#    - Generate a strong SECRET_KEY: python -c 'import secrets; print(secrets.token_hex(24))'
#    - Use strong database passwords
#    - Set FLASK_DEBUG=false
#    - Always use HTTPS in production (SESSION_COOKIE_SECURE=true)
#
# 2. DATABASE SETUP:
#    - Ensure PostgreSQL is running
#    - Create database and user as per PRODUCTION.md guide
#    - Test connection before deployment
#
# 3. BACKUP CONFIGURATION:
#    - Set BACKUP_LOCATION to a location with sufficient disk space
#    - Ideally on a separate disk from the application
#    - For true disaster recovery, regularly copy backups to external storage
#    - Monitor disk space to prevent backup failures
#
# 4. SCHEDULER:
#    - APScheduler is configured for automated backups
#    - Configure schedule via admin UI: /admin/backup
#    - Ensure application is always running for scheduled backups to work
#    - Use systemd/supervisord to auto-restart if crashed
#
# 5. MONITORING:
#    - Regularly test restore operations
#    - Monitor backup logs for errors
#    - Set up alerts for backup failures (email notifications - future feature)
